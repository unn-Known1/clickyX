{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ClickyX",
  "mainBinaryName": "clickyx",
  "version": "0.1.1",
  "identifier": "com.clickyx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ClickyX",
        "width": 356,
        "height": 500,
        "minWidth": 356,
        "minHeight": 300,
        "maxHeight": 720,
        "decorations": false,
        "center": true,
        "focus": true,
        "visible": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "ClickyX"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.clickyx.app https://api.openai.com https://api.anthropic.com https://api.deepgram.com https://api.elevenlabs.io wss://api.deepgram.com; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayIcon": "icons/icon.ico",
        "languages": ["English"],
        "webviewInstallMode": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "privacyDescriptions": {
        "NSCameraUsageDescription": "ClickyX needs camera access for screen context and visual analysis",
        "NSMicrophoneUsageDescription": "ClickyX needs microphone access for voice commands and audio features",
        "NSScreenCaptureUsageDescription": "ClickyX needs screen recording permission for automation and context awareness",
        "NSAppleEventsUsageDescription": "ClickyX needs accessibility access to control other applications on your behalf"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libxdo1",
          "librsvg2-2",
          "libasound2",
          "libappindicator3-1"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": ["openclicky"]
      }
    }
  }
}
