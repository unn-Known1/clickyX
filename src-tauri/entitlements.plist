<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- JIT + unsigned memory: needed for macOSPrivateApi (transparent overlay windows) -->
    <key>com.apple.security.cs.allow-jit</key><true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
    <!-- Hardware access -->
    <key>com.apple.security.device.audio-input</key><true/>
    <key>com.apple.security.device.camera</key><true/>
    <key>com.apple.security.screen-capture</key><true/>
    <!-- Network (outbound only — localhost bridge does not need incoming connections) -->
    <key>com.apple.security.network.client</key><true/>
    <!-- Accessibility: needed for osascript System Events control -->
    <key>com.apple.security.automation.apple-events</key><true/>
</dict>
</plist>
